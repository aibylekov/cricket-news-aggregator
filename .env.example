# Copy this file to .env and fill in. .env is gitignored and never committed.

# --- Body extraction fallback (Phase 3) — for anti-bot blocked sites ---
# Zyte API key; used only when the free trafilatura fetch hits 403
# (News18, NDTV, ESPNcricinfo, Indian Express). Other sites never hit Zyte.
ZYTE_API_KEY=

# --- Article combining (Phase 5) — fill in ONE provider only ---
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=   # alternative to OpenAI if you use Claude instead

# --- Email notifications (Phase 6), if used ---
EMAIL_USER=
EMAIL_PASSWORD=
