# Copy this file to .env and fill in. .env is gitignored and never committed.

# --- Body extraction fallback (Phase 3) — for anti-bot blocked sites ---
# Zyte API key; used only when the free trafilatura fetch hits 403
# (News18, NDTV, ESPNcricinfo, Indian Express). Other sites never hit Zyte.
ZYTE_API_KEY=

# --- Article combining (Phase 5) — fill in ONE provider only ---
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=   # alternative to OpenAI if you use Claude instead

# --- Review-email delivery (Phase 6) ---
# Newly combined, non-duplicate articles are emailed to a human reviewer.
# Sent via SMTP over SSL on port 465 (smtplib.SMTP_SSL, NOT STARTTLS).
# If ANY of these is empty, the pipeline does a dry-run (logs "would send")
# instead of sending — so it stays testable before credentials are added.
EMAIL_FROM=
EMAIL_TO=
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
