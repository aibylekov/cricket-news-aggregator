# Виртуална среда — не се качва (голяма и машинно-специфична)
venv/
.venv/

# Тайни — НИКОГА в Git
.env

# Python кеш
__pycache__/
*.pyc
*.pyo

# Локална база данни — НЕ влиза в Git (расте неограничено). Персистенцията
# между Actions пусканията вече е през cache, а архивът — през артефакт.
*.db
*.sqlite
*.sqlite3
# ИЗКЛЮЧЕНИЕ: само малкото статично начално състояние (seed) е в Git — то сидва
# работната база при първо пускане (cache miss). Не расте, обновява се рядко.
!data/seed.db

# Системни / редакторски файлове
Thumbs.db
.DS_Store
.vscode/
.idea/
